# Backend-only env (loaded by server/src/config.ts). NEVER bundled into the
# browser. Do NOT prefix any of these with VITE_, and never commit real
# values — keep them in .env.local (gitignored).
REDMINE_BASE_URL=https://redmine.example.com
REDMINE_API_KEY=replace-me
REDMINE_READ_ONLY=true
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Frontend env (Vite reads these and bundles them). Never put secrets here.
VITE_MOCK_MODE=true
VITE_API_BASE=/api/redmine

# ─── Admin & Audit (optional; plan §14) ───────────────────────────────
# If any of ADMIN_USER / ADMIN_PASSWORD_HASH / SESSION_SECRET is missing,
# /api/auth and /api/admin return 501 and the admin page is hidden.
# Generate ADMIN_PASSWORD_HASH with: node server/scripts/hash-password.mjs '<password>'
# Generate SESSION_SECRET with    : openssl rand -base64 48
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=replace-me
SESSION_SECRET=replace-me-at-least-32-bytes
HISTORY_DB=./server/data/history.jsonl
# Set true in production behind HTTPS. Leave false for http://localhost dev.
COOKIE_SECURE=false

# ─── Microsoft Entra sign-in (MSAL Node auth-code; optional, flag-gated) ───
# When MS_AUTH_ENABLED=true, the whole app requires Microsoft sign-in. Leave
# false until the REDIRECT_URI below is registered in the app registration
# (Azure portal → App registrations → your app → Authentication → Web →
# Redirect URIs). The client secret is server-side only.
# MS_AUTH_ENABLED=false
# MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MSAL_TENANT_ID=00000000-0000-0000-0000-000000000000
# MSAL_CLOUD_INSTANCE=https://login.microsoftonline.com/
# MSAL_CLIENT_SECRET=replace-me
# MSAL_REDIRECT_URI=http://localhost:5173/api/auth/ms/redirect
# MSAL_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ─── Multi-instance session + rate-limit store (optional; plan §13) ───
# When set, the session store and rate-limit middleware use Redis so they
# survive restarts and shard across backend instances. When unset (default),
# both fall back to process-local maps — fine for a single-process deploy.
# REDIS_URL=redis://localhost:6379

# ─── Dynamics 365 / Dataverse CRM (optional; CR #21) ──────────────────
# A single app-registration (service principal) the BACKEND uses to read
# CRM data on behalf of the whole site — configured once, not per user.
# When unset, CRM features stay dormant.
#   DATAVERSE_URL          : Power Platform admin center → your environment URL (no trailing slash)
#   DATAVERSE_TENANT_ID    : Entra ID → App registrations → your app → Directory (tenant) ID
#   DATAVERSE_CLIENT_ID    : same app → Application (client) ID
#   DATAVERSE_CLIENT_SECRET: same app → Certificates & secrets → secret VALUE (rotates on expiry)
# NOTE: the app registration must also be added as an Application User in
# Dataverse with a security role granting read on the target tables.
# DATAVERSE_URL=https://YOURORG.crm.dynamics.com
# DATAVERSE_TENANT_ID=00000000-0000-0000-0000-000000000000
# DATAVERSE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# DATAVERSE_CLIENT_SECRET=replace-me
