# Backend-only env (loaded by server/src/config.ts). NEVER bundled into the
# browser. Do NOT prefix any of these with VITE_, and never commit real
# values — keep them in .env.local (gitignored).
REDMINE_BASE_URL=https://redmine.example.com
REDMINE_API_KEY=replace-me
REDMINE_READ_ONLY=true
PORT=8787
ALLOWED_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Frontend env (Vite reads these and bundles them). Never put secrets here.
VITE_MOCK_MODE=true
VITE_API_BASE=/api/redmine

# ─── Admin & Audit (optional; plan §14) ───────────────────────────────
# If any of ADMIN_USER / ADMIN_PASSWORD_HASH / SESSION_SECRET is missing,
# /api/auth and /api/admin return 501 and the admin page is hidden.
# Generate ADMIN_PASSWORD_HASH with: node server/scripts/hash-password.mjs '<password>'
# Generate SESSION_SECRET with    : openssl rand -base64 48
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=replace-me
SESSION_SECRET=replace-me-at-least-32-bytes
HISTORY_DB=./server/data/history.jsonl
# Set true in production behind HTTPS. Leave false for http://localhost dev.
COOKIE_SECURE=false

# ─── Multi-instance session + rate-limit store (optional; plan §13) ───
# When set, the session store and rate-limit middleware use Redis so they
# survive restarts and shard across backend instances. When unset (default),
# both fall back to process-local maps — fine for a single-process deploy.
# REDIS_URL=redis://localhost:6379
