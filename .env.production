# Frontend production build config — Vite auto-loads this for `vite build`.
# VITE_* values are baked into the client bundle; NEVER put secrets here.
# Backend secrets (REDMINE_*, DATAVERSE_*, SESSION_SECRET, …) come from the
# Azure App Service "Application settings", read at runtime via process.env.
VITE_MOCK_MODE=false
VITE_API_BASE=/api/redmine
